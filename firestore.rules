rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAdmin() {
      return request.auth != null && request.auth.token.email == 'admin@gmail.com';
    }

    // User Profiles
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Strategies (Top-Level Collection)
    match /strategies/{strategyId} {
      allow read, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null 
                    && resource.data.userId == request.auth.uid 
                    && request.resource.data.userId == request.auth.uid;
    }
    
    // Backtests (Top-Level Collection)
    match /backtests/{backtestId} {
      allow read, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null 
                    && resource.data.userId == request.auth.uid 
                    && request.resource.data.userId == request.auth.uid;
    }
    
    // Live Deployments (Top-Level Collection)
    match /deployments/{deploymentId} {
      allow read, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null 
                    && resource.data.userId == request.auth.uid 
                    && request.resource.data.userId == request.auth.uid;
    }

    // Trades
    match /trades/{tradeId} {
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    }

    // Templates
    match /templates/{templateId} {
      allow read: if request.auth != null;
    }

    // Announcements
    match /announcements/{announcementId} {
      allow read: if request.auth != null;
      allow update: if request.auth != null 
                    && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['seenBy']);
    }

    // Notifications
    match /notifications/{notificationId} {
      allow read, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid || resource.data.userEmail == request.auth.token.email);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null 
                    && (resource.data.userId == request.auth.uid || resource.data.userEmail == request.auth.token.email);
    }

    // Portfolio & Market Scans
    match /portfolio/{itemId} {
      allow read, delete: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow update: if request.auth != null 
                    && resource.data.userId == request.auth.uid 
                    && request.resource.data.userId == request.auth.uid;
    }

    // Subscriptions & Payments
    match /subscriptions/{subscriptionId} {
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
    }
    match /payments/{paymentId} {
      allow read: if request.auth != null && (resource == null || resource.data.userId == request.auth.uid);
    }

    // Sales Inquiries
    match /sales_inquiries/{inquiryId} {
      allow create: if true;
    }

    // Global Admin Access
    match /{document=**} {
      allow read, write: if isAdmin();
    }
  }
}
